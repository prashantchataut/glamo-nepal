# GLAMO NEPAL environment variables
# Copy to .env.local for local development. Never commit real secrets.

# ─── Site ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Firebase Auth ───
# Get these from Firebase Console → Project Settings → Web App
# CRITICAL: NEXT_PUBLIC_FIREBASE_PROJECT_ID is required for auth middleware.
# Without it, all protected routes (/account, /checkout) will block access.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Backend API ───
# Server-side only (not exposed to browser). Points at the Worker so the
# /api/v1 proxy route (src/app/api/v1/[[...slug]]/route.ts) can forward requests.
API_BASE_URL=
# Shared secret used by the frontend /api/v1 proxy and the Worker backend to
# trust proxied requests. Must match the Worker's PROXY_TRUST_SECRET.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROXY_TRUST_SECRET=change-me
# Client-side (exposed to browser). MUST be same-origin ("/api/v1") in production.
#
# Why NOT the Worker URL: the admin session cookie is a __Host- cookie
# (HttpOnly, SameSite=Strict, host-only on the frontend domain) — it can never
# be sent to a different origin like *.workers.dev. Pointing this at the Worker
# directly makes every authenticated admin call fail (cookie absent → 401/404).
# Routing through the same-origin "/api/v1" proxy lets the cookie travel
# server-side to the Worker. The proxy uses API_BASE_URL (server-only) to reach
# the Worker.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
# Production value: NEXT_PUBLIC_API_BASE_URL=/api/v1

# ─── Payment Gateways ───
# Khalti (https://khalti.com/merchant)
# Test environment: use https://a.khalti.com/api/ as base URL
# Live environment: use https://khalti.com/api/ as base URL
NEXT_PUBLIC_KHALTI_PUBLIC_KEY=
KHALTI_SECRET_KEY=
# eSewa (https://esewa.com.np/merchant)
# Test environment: use https://uat.esewa.com.np/ as base URL
# Live environment: use https://esewa.com.np/ as base URL
NEXT_PUBLIC_ESEWA_MERCHANT_ID=
ESEWA_SECRET_KEY=
ESEWA_MERCHANT_CODE=

# ─── Admin ───
# Generate strong random values!
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_EMAIL=
# ADMIN_PASSWORD: plaintext fallback for development only. DO NOT use in production.
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH: bcrypt hash (preferred in production)
# Generate: npx tsx scripts/hash-password.ts <password>
ADMIN_PASSWORD_HASH=
# Session secrets (generate random 64-char hex strings)
ADMIN_SESSION_SECRET=
AUTH_SECRET=
# CSRF_SECRET: Used for signing CSRF tokens. Required in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=
ADMIN_NAME=
# Comma-separated emails for super admin access (first email is the OWNER)
SUPER_ADMIN_EMAILS=

# ─── Images ───
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─── Analytics ───
# Google Analytics 4 measurement ID (G-XXXX). The gtag snippet is injected by
# src/components/seo/GoogleAnalytics.tsx using next/script (nonce-aware, CSP-safe).
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# ─── Email ───
# Resend (https://resend.com) for transactional emails
RESEND_API_KEY=

# ─── Social ───
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/glamo_nepal/
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/glamonepal

# ─── Rate Limiting (Required in Production) ───
# Upstash Redis for serverless rate limiting and idempotency
# REQUIRED in production — without these, all rate-limited endpoints return 429
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cloudflare Web Analytics ───
# Get the beacon token from Cloudflare Dashboard → Speed → Observability → Web Analytics
# Leave empty to disable analytics
NEXT_PUBLIC_CF_BEACON_ID=