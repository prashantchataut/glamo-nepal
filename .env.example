# GLAMO Nepal Backend - Development Environment
# Copy to .env and fill in real values

# Turso Database
TURSO_DB_URL=libsql://your-db-name-your-org.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id

# Email (Resend)
RESEND_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payment Gateways
KHALTI_SECRET_KEY=
ESEWA_SECRET_KEY=
ESEWA_MERCHANT_CODE=

# Frontend
FRONTEND_URL=http://localhost:3000

# Admin session secrets (must match frontend AUTH_SECRET/ADMIN_SESSION_SECRET)
AUTH_SECRET=
ADMIN_SESSION_SECRET=

# Super admin emails (comma-separated, first is OWNER)
SUPER_ADMIN_EMAILS=

# Pricing
FREE_SHIPPING_THRESHOLD=2500
COD_FEE=50

# Rate Limiting (Required in Production)
# Upstash Redis for serverless rate limiting and idempotency
# Without these, rate limiting falls back to per-invocation memory (useless on serverless)
# Get credentials from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=