# GLAMO NEPAL environment variables
# Copy to .env.local for local development. Never commit real secrets.

# ─── Site ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Firebase Auth ───
# Get these from Firebase Console → Project Settings → Web App
# CRITICAL: NEXT_PUBLIC_FIREBASE_PROJECT_ID is required for auth middleware.
# Without it, all protected routes (/account, /checkout) will block access.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Backend API ───
# Server-side only (not exposed to browser):
API_BASE_URL=
# Client-side (exposed to browser):
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# ─── Payment Gateways ───
# Khalti (https://khalti.com/merchant)
NEXT_PUBLIC_KHALTI_PUBLIC_KEY=
KHALTI_SECRET_KEY=
# eSewa (https://esewa.com.np/merchant)
NEXT_PUBLIC_ESEWA_MERCHANT_ID=
ESEWA_SECRET_KEY=
ESEWA_MERCHANT_CODE=

# ─── Admin ───
# Generate strong random values!
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
AUTH_SECRET=
ADMIN_NAME=

# ─── Images ───
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─── Analytics ───
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# ─── Email ───
# Resend (https://resend.com) for transactional emails
RESEND_API_KEY=

# ─── Social ───
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/glamo_nepal/
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/glamonepal