# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# lock files (pnpm is primary)
package-lock.json

# backend dev server
dev.pid

# backend build output
backend/dist/

# env files
.env
.env*.local
.env.production
.env.production.local
# Secret rotation runbook (contains live secrets)
.env.rotation-pending.local.md

# backend wrangler config is tracked but MUST NOT contain secrets.
# Set all secrets via `wrangler secret put` (stored in Cloudflare dashboard).

# vercel
.vercel

# netlify
.netlify

# typescript
*.tsbuildinfo
next-env.d.ts

# opencode config
.opencode/

# superpowers specs
docs/superpowers/

# binary archives
*.zip

# graphify generated output
graphify-out/

.open-next/

# Cloudflare Wrangler local state/build artifacts
.wrangler/

# Windows cmd.exe redirection accidents (on Windows `> nul` can create a real file)
nul
backend/nul

# Stray scratch output (not source)
tracked.txt

cookie*.txt
cookie*.txt.signed
token*.txt
