# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# lock files (pnpm is primary)
package-lock.json

# backend dev server
dev.pid

# backend build output
backend/dist/

# ─── env files ──────────────────────────────────────────────────────────────
# ALL env files containing real values are ignored. Only .env.example is tracked.
# If .env.local or .env.production are already tracked in git, remove them with:
#   git rm --cached .env.local .env.production
# Then purge them from history with scripts/purge-leaked-env.sh (in the fix pack).
.env
.env*.local
.env.production
.env.production.local
.env.rotation-pending.local.md

# backend wrangler config is tracked but MUST NOT contain secrets.
# Set all secrets via `wrangler secret put` (stored in Cloudflare dashboard).

# vercel
.vercel

# netlify
.netlify

# typescript
*.tsbuildinfo
next-env.d.ts

# opencode config
.opencode/

# superpowers specs
docs/superpowers/

# binary archives
*.zip

# graphify generated output
graphify-out/

# OpenNext build output (Cloudflare Workers frontend — currently unused, see PLATFORM_DECISION.md)
.open-next/

# Cloudflare Wrangler local state/build artifacts
.wrangler/

# ─── Build artifacts that should never be tracked ───────────────────────────
# A pre-built minified Cloudflare Worker bundle was accidentally committed in
# commit 7a1426e. It bloats the repo and confuses tooling. Never track it.
dist/
backend/dist/

# Windows cmd.exe redirection accidents (on Windows `> nul` can create a real file)
nul
backend/nul

# Stray scratch output (not source)
tracked.txt

cookie*.txt
cookie*.txt.signed
token*.txt

_jarvis_probe.ps1

# ─── AI-generated fix-pack artifacts (delete after merging) ─────────────────
# These were one-shot patch files from an earlier AI session. They should not
# live in the repo long-term.
apply-changes.sh
changes.patch
HOW_TO_APPLY.md
README-CHANGES.md
