{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": [
    "@typescript-eslint",
    "react-hooks",
    "@next/next"
  ],
  "extends": [],
  "rules": {
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn",
    "@next/next/no-img-element": "warn"
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "out/",
    "build/",
    ".open-next/",
    "public/",
    "backend/dist/",
    "backend/.wrangler/",
    "dist/",
    "*.config.js",
    "*.config.mjs",
    "*.config.cjs",
    "*.config.ts",
    "next-env.d.ts",
    "coverage/",
    "playwright-report/",
    "test-results/",
    "scripts/"
  ]
}