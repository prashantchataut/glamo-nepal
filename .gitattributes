# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Config
*.json text eol=lf
*.jsonc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.cjs text eol=lf

# Docs
*.md text eol=lf
*.mdx text eol=lf

# Lock files
package-lock.json text eol=lf
pnpm-lock.yaml text eol=lf

# Binary files (no normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.webp binary
*.mp4 binary
*.webm binary