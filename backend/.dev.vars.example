# GLAMO Nepal Backend — Local Development Variables
# Copy this file to .env and fill in real values
# NEVER commit real secrets to git!

# ── Turso Database (REQUIRED) ──────────────────────────────────────────────
# Get these from: Turso Dashboard → Database → Settings
TURSO_DB_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Firebase Auth (REQUIRED) ───────────────────────────────────────────────
# Your Firebase project ID for JWT verification
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Cloudinary (REQUIRED for image uploads) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx

# ── Payments ──────────────────────────────────────────────────────────────
KHALTI_SECRET_KEY=test_secret_key_xxx
ESEWA_SECRET_KEY=xxx
ESEWA_MERCHANT_CODE=xxx

# ── Frontend URL (for CORS) ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Pricing ───────────────────────────────────────────────────────────────
FREE_SHIPPING_THRESHOLD=2500
COD_FEE=50