# Cloudflare Workers Environment Variables
# Copy this file to .dev.vars for local development

# JWT Keys (RS256 PEM format)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=

# R2 Storage
R2_PUBLIC_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payments
KHALTI_SECRET_KEY=
ESEWA_SECRET_KEY=
ESEWA_MERCHANT_CODE=

# App Config (set in wrangler.toml [vars])
# FRONTEND_URL=http://localhost:3000
# FREE_SHIPPING_THRESHOLD=2500
# COD_FEE=50
# ADMIN_EMAIL=set-via-wrangler-secret