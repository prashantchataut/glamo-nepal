  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.19.39",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "glob": "^10.5.0",
    "next": {
      "postcss": "^8.5.10"
    }
  }
