{
  "name": "glamo-nepal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "static:check": "bash scripts/static-check.sh",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate": "npm run static:check && npm run typecheck && npm run lint && npm run build",
    "routes:check": "node scripts/check-routes.mjs",
    "imports:check": "node scripts/check-local-imports.mjs",
    "content:check": "node scripts/check-content.mjs",
    "qa:static": "npm run content:check && npm run routes:check && npm run imports:check && npm run smoke:routes && npm run stores:check && npm run product-data:check && npm run a11y:source && npm run env:check && npm run perf:source",
    "product-data:check": "node scripts/check-product-data.mjs",
    "a11y:source": "node scripts/check-a11y-source.mjs",
    "env:check": "node scripts/check-env-example.cjs",
    "preflight": "npm run qa:static && npm run typecheck && npm run lint && npm run build",
    "smoke:routes": "node scripts/check-smoke-routes.mjs",
    "stores:check": "node scripts/check-store-contracts.mjs",
    "perf:source": "node scripts/check-performance-source.mjs",
    "test:smoke": "npm run smoke:routes && npm run stores:check"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
